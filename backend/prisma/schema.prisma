generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  TALENT
  ADMIN
}

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  passwordHash    String
  firstName       String
  lastName        String
  role            UserRole    @default(CLIENT)
  bio             String?     @db.Text
  location        String?
  hourlyRateCents Int?
  avatarUrl       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  profile         Profile?
  skills          UserSkill[]
  reviewsGiven    Review[] @relation("ReviewsGiven")
  reviewsReceived Review[] @relation("ReviewsReceived")

  //⬇ requests relations (client => talent / sent & received) ⬇
  clientRequests Request[] @relation("ClientRequests")
  talentRequests Request[] @relation("TalentRequests")

  @@index([role])
  @@index([location])
}

model Profile {
  id              String            @id @default(cuid())
  userId          String            @unique
  headline        String?
  bio             String?           @db.Text
  location        String?
  hourlyRateCents Int?
  avatarUrl       String?
  availability    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillTags       ProfileSkillTag[]

  @@index([location])
}

model SkillTag {
  id        String            @id @default(cuid())
  name      String            @unique
  createdAt DateTime          @default(now())
  profiles  ProfileSkillTag[]
}

model ProfileSkillTag {
  profileId String
  skillTagId String
  createdAt DateTime @default(now())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skillTag  SkillTag @relation(fields: [skillTagId], references: [id], onDelete: Cascade)

  @@id([profileId, skillTagId])
}

model Skill {
  id        String      @id @default(cuid())
  name      String      @unique
  createdAt DateTime    @default(now())
  users     UserSkill[]
}

model UserSkill {
  userId    String
  skillId   String
  years     Int?
  createdAt DateTime @default(now())
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
}

model Review {
  id         String   @id @default(cuid())
  rating     Int      // e.g., 1 to 5 stars
  comment    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Foreign Keys
  reviewerId String
  revieweeId String

  // Relations
  reviewer   User     @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee   User     @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)
}

// REQUESTS

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Request {
  id            String   @id @default(cuid())

  title         String
  message       String   @db.Text
  proposedPrice Int?

  status        RequestStatus @default(PENDING)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clientId      String
  talentId      String

  client        User @relation("ClientRequests", fields: [clientId], references: [id], onDelete: Cascade)
  talent        User @relation("TalentRequests", fields: [talentId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([talentId])
  @@index([status])
}